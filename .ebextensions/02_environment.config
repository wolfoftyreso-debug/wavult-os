# =============================================
# Elastic Beanstalk — Miljövariabler
# OBS: Sätt dessa via EB Console eller eb setenv
# Lägg ALDRIG riktiga nycklar i denna fil!
# =============================================
# Kör: eb setenv SUPABASE_URL=https://... SUPABASE_SERVICE_ROLE_KEY=...
#
# Alla variabler hanteras via AWS Parameter Store
# eller direkt via EB environment properties.
# Se docs/aws-setup.md för instruktioner.

option_settings:
  aws:elasticbeanstalk:application:environment:
    NODE_ENV: production
    PORT: 8080
    CORS_ORIGIN: "https://app.hypbit.com"
    # Känsliga nycklar sätts via eb setenv eller Parameter Store:
    # SUPABASE_URL
    # SUPABASE_ANON_KEY
    # SUPABASE_SERVICE_ROLE_KEY
    # STRIPE_SECRET_KEY
    # STRIPE_WEBHOOK_SECRET
    # TRIGGER_API_KEY
    # ANTHROPIC_API_KEY
