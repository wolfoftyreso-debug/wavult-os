    {
      "name": "Currency",
      "item": [
        {
          "name": "List Currencies",
          "request": { "method": "GET", "url": "{{BASE_URL}}/api/currencies", "auth": { "type": "noauth" } }
        },
        {
          "name": "Exchange Rates",
          "request": { "method": "GET", "url": "{{BASE_URL}}/api/exchange-rates" }
        },
        {
          "name": "Convert Currency",
          "request": {
            "method": "GET",
            "url": { "raw": "{{BASE_URL}}/api/convert?amount=1000&from=USD&to=SEK", "query": [{ "key": "amount", "value": "1000" }, { "key": "from", "value": "USD" }, { "key": "to", "value": "SEK" }] }
          }
        },
        {
          "name": "FX Exposure",
          "request": { "method": "GET", "url": "{{BASE_URL}}/api/fx/exposure" }
        },
        {
          "name": "FX Adjustments",
          "request": { "method": "GET", "url": "{{BASE_URL}}/api/fx/adjustments" }
        },
        {
          "name": "Multi-currency Pipeline",
          "request": { "method": "GET", "url": { "raw": "{{BASE_URL}}/api/deals/pipeline/multi?currency=SEK", "query": [{ "key": "currency", "value": "SEK" }] } }
        }
      ]
    },

    {
      "name": "Reports",
      "item": [
        {
          "name": "Chart of Accounts",
          "request": { "method": "GET", "url": "{{BASE_URL}}/api/reports/chart-of-accounts", "auth": { "type": "noauth" } }
        },
        {
          "name": "Income Statement",
          "request": { "method": "GET", "url": { "raw": "{{BASE_URL}}/api/reports/income-statement?from=2026-01-01&to=2026-03-31", "query": [{ "key": "from", "value": "2026-01-01" }, { "key": "to", "value": "2026-03-31" }] } }
        },
        {
          "name": "Balance Sheet",
          "request": { "method": "GET", "url": { "raw": "{{BASE_URL}}/api/reports/balance-sheet?date=2026-03-31", "query": [{ "key": "date", "value": "2026-03-31" }] } }
        },
        {
          "name": "General Ledger",
          "request": { "method": "GET", "url": { "raw": "{{BASE_URL}}/api/reports/general-ledger?from=2026-01-01&to=2026-03-31", "query": [{ "key": "from", "value": "2026-01-01" }, { "key": "to", "value": "2026-03-31" }] } }
        },
        {
          "name": "VAT Report",
          "request": { "method": "GET", "url": { "raw": "{{BASE_URL}}/api/reports/vat?from=2026-01-01&to=2026-03-31", "query": [{ "key": "from", "value": "2026-01-01" }, { "key": "to", "value": "2026-03-31" }] } }
        },
        {
          "name": "Cashflow Statement",
          "request": { "method": "GET", "url": { "raw": "{{BASE_URL}}/api/reports/cashflow?from=2026-01-01&to=2026-03-31", "query": [{ "key": "from", "value": "2026-01-01" }, { "key": "to", "value": "2026-03-31" }] } }
        },
        {
          "name": "SIE4 Export",
          "request": { "method": "GET", "url": { "raw": "{{BASE_URL}}/api/reports/sie4?from=2026-01-01&to=2026-12-31", "query": [{ "key": "from", "value": "2026-01-01" }, { "key": "to", "value": "2026-12-31" }] } }
        }
      ]
    },

    {
      "name": "Stripe",
      "item": [
        {
          "name": "List Plans",
          "request": { "method": "GET", "url": "{{BASE_URL}}/api/stripe/plans", "auth": { "type": "noauth" } }
        },
        {
          "name": "Create Checkout Session",
          "request": {
            "method": "POST",
            "url": "{{BASE_URL}}/api/stripe/create-checkout-session",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"plan_id\":\"growth\",\"success_url\":\"https://app.pixdrift.com/success\",\"cancel_url\":\"https://app.pixdrift.com/billing\"}" }
          }
        }
      ]
    },

    {
      "name": "API Keys (Admin)",
      "item": [
        {
          "name": "List API Keys",
          "request": { "method": "GET", "url": "{{BASE_URL}}/api/admin/api-keys" }
        },
        {
          "name": "Create API Key",
          "request": {
            "method": "POST",
            "url": "{{BASE_URL}}/api/admin/api-keys",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"name\":\"My Integration\",\"scopes\":[\"read\",\"write\"]}" }
          },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 201', () => pm.response.to.have.status(201));", "pm.test('Has key field', () => pm.expect(pm.response.json()).to.have.property('key'));"] } }]
        },
        {
          "name": "Revoke API Key",
          "request": { "method": "DELETE", "url": "{{BASE_URL}}/api/admin/api-keys/{{api_key_id}}" }
        }
      ]
    }

  ]
