# wavult-core environment variables
# Copy to .env for local dev — production values live in AWS SSM

# ── Database ──────────────────────────────────────────────────────────────────
RDS_HOST=                              # Required: wavult-identity-ecs.xxx.eu-north-1.rds.amazonaws.com
RDS_PORT=5432
RDS_DATABASE=wavult_identity
RDS_USER=wavult_admin
RDS_PASSWORD=                          # SSM: /wavult/prod/RDS_PASSWORD

# ── Auth (identity-core JWT) ──────────────────────────────────────────────────
JWT_SECRET=dev-secret-change-in-production   # Dev only — prod uses KMS
JWT_ISSUER=identity.wavult.com
SERVICE_AUDIENCE=wavult-os
KMS_KEY_ID=                            # SSM: /wavult/prod/KMS_KEY_ID (prod only)

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=eu-north-1
S3_BUCKET=wavult-images-eu-primary

# ── Supabase (self-hosted) ────────────────────────────────────────────────────
SUPABASE_URL=                          # http://your-supabase-host:8000
SUPABASE_SERVICE_KEY=                  # SSM: /wavult/prod/SUPABASE_SERVICE_KEY

# ── Revolut Business API ──────────────────────────────────────────────────────
REVOLUT_ACCESS_TOKEN=                  # SSM: /wavult/prod/REVOLUT_ACCESS_TOKEN
REVOLUT_REFRESH_TOKEN=                 # SSM: /wavult/prod/REVOLUT_REFRESH_TOKEN
REVOLUT_BUSINESS_CLIENT_ID=            # OAuth client ID
REVOLUT_BUSINESS_ACCOUNT_ID=          # Account to pay from
REVOLUT_BUSINESS_PRIVATE_KEY=         # Path to PEM file or SSM

# ── AI Providers ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=                     # SSM: /wavult/prod/ANTHROPIC_API_KEY
OPENAI_API_KEY=                        # SSM: /wavult/prod/OPENAI_API_KEY
ELEVENLABS_API_KEY=                    # SSM: /wavult/prod/ELEVENLABS_API_KEY
GEMINI_API_KEY=                        # SSM: /wavult/prod/GEMINI_API_KEY
DID_API_KEY=                           # SSM: /wavult/prod/DID_API_KEY

# ── Bernt / OpenClaw Integration ──────────────────────────────────────────────
INTERNAL_SERVICE_SECRET=               # SSM: /wavult/prod/INTERNAL_SERVICE_SECRET
OPENCLAW_WEBHOOK_SECRET=               # SSM: /wavult/prod/OPENCLAW_WEBHOOK_SECRET
# Used by OpenClaw/Bernt to call /v1/bernt/* endpoints

# ── Twilio ────────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=                    # SSM: /wavult/prod/TWILIO_ACCOUNT_SID
TWILIO_AUTH_TOKEN=                     # SSM: /wavult/prod/TWILIO_AUTH_TOKEN

# ── Service ───────────────────────────────────────────────────────────────────
PORT=3007
NODE_ENV=development                   # development | production
