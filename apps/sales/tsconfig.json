{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "paths": {
      "@pixdrift/i18n": [
        "../../packages/i18n/src/index.ts"
      ],
      "@pixdrift/i18n/*": [
        "../../packages/i18n/src/*"
      ]
    }
  },
  "include": [
    "src"
  ]
}
